# ─────────────────────────────────────────────────────────────────────────────
# Dr Tooth — environment template. Copy to .env.local and fill real values.
# NO SECRETS IN THIS FILE. .env.local is gitignored; this template is committed.
# ─────────────────────────────────────────────────────────────────────────────

# ── Data backend switch (Firebase ↔ Supabase migration) ──────────────────────
# "firebase" (default) keeps the current live behaviour. "supabase" routes ALL
# wired data access through Supabase (full cutover).
DATA_BACKEND=firebase
# Granular per-area opt-in (used while DATA_BACKEND=firebase). Comma-separated.
# Phase 2 wires the high-frequency ephemeral counters: set to "counters" to move
# idempotency/send-budget/abuse/ai-budget/rate-limit off Firestore onto Supabase RPCs.
# Requires the SQL migrations applied + SUPABASE_SERVICE_ROLE_KEY set.
SUPABASE_AREAS=

# ── Supabase ─────────────────────────────────────────────────────────────────
# Public (browser-safe) — governed by Row Level Security.
NEXT_PUBLIC_SUPABASE_URL=https://cflrtbpmujrsvruncqwj.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
# Older Supabase projects may call this the anon key. Either public key name works.
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Server-ONLY. Bypasses RLS. Used by the bot/cron/webhook admin client.
# NEVER prefix with NEXT_PUBLIC_. Get it from Supabase → Project Settings → API.
SUPABASE_SERVICE_ROLE_KEY=

# ── OpenAI (AI receptionist) ─────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Firebase Admin (Firestore server access — used until Supabase path proven) ─
FIREBASE_ADMIN_PROJECT_ID=dr-tooth-dental-clinic
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY=

# ── WhatsApp gateway (OpenWA) ────────────────────────────────────────────────
OPENWA_API_URL=
OPENWA_API_KEY=
OPENWA_SESSION_ID=
OPENWA_WEBHOOK_SECRET=
WEBHOOK_REJECT_UNSIGNED=true
